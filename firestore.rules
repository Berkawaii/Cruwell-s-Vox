rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function for Auth
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function for Admin
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Default: Authenticated users can read everything
    match /{document=**} {
      allow read: if isSignedIn();
    }

    // Users Collection
    match /users/{userId} {
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // Text Chat Rooms
    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /participants/{participantId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isSignedIn() && request.auth.uid == participantId;
      }
      
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isAdmin();
        allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.uid);
      }
    }

    // WebRTC Rooms & Participants
    match /webrtc_rooms/{roomId} {
      allow read, write: if isSignedIn();
      
      match /participants/{participantId} {
        allow read, write: if isSignedIn();
        
        match /connections/{connectionId} {
          allow read, write: if isSignedIn();
          
          match /callerCandidates/{candidateId} { allow read, write: if isSignedIn(); }
          match /calleeCandidates/{candidateId} { allow read, write: if isSignedIn(); }
        }
      }
    }

    // Channels
    match /channels/{channelId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Server Config (Password)
    match /config/server {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
